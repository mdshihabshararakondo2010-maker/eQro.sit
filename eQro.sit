<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>eQro PDF Hub - শিক্ষামূলক PDF হাব</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            color: #333;
        }
        
        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .logo {
            font-size: 28px;
            font-weight: bold;
            color: #2e7d32;
            cursor: pointer;
            padding: 10px 20px;
            border-radius: 50px;
            background: linear-gradient(45deg, #43a047, #66bb6a);
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        
        .logo:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(67, 160, 71, 0.4);
        }
        
        .header-icons {
            display: flex;
            gap: 15px;
        }
        
        .icon-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(45deg, #43a047, #66bb6a);
            color: white;
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            box-shadow: 0 5px 20px rgba(67, 160, 71, 0.3);
        }
        
        .icon-btn:hover {
            transform: scale(1.1) rotate(10deg);
            box-shadow: 0 10px 30px rgba(67, 160, 71, 0.5);
        }
        
        /* Navigation */
        .nav {
            background: rgba(46, 125, 50, 0.95);
            backdrop-filter: blur(20px);
            padding: 20px 0;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .nav-btn {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            padding: 15px 30px;
            border-radius: 50px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 500;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }
        
        .nav-btn:hover, .nav-btn.active {
            background: white;
            color: #2e7d32;
            border-color: #43a047;
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255, 255, 255, 0.3);
        }
        
        /* Page Container */
        .page-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
            min-height: calc(100vh - 200px);
        }
        
        .page {
            display: none;
        }
        
        .page.active {
            display: block;
            animation: slideIn 0.5s ease-out;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Hero Section */
        .hero {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 80px 60px;
            text-align: center;
            margin-bottom: 60px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }
        
        .hero h1 {
            font-size: 48px;
            color: #2e7d32;
            margin-bottom: 25px;
            font-weight: 700;
        }
        
        .hero p {
            font-size: 20px;
            color: #666;
            margin-bottom: 50px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.8;
        }
        
        .cta-buttons {
            display: flex;
            gap: 30px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .cta-btn {
            background: linear-gradient(45deg, #43a047, #66bb6a);
            color: white;
            padding: 20px 50px;
            border: none;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(67, 160, 71, 0.4);
            text-decoration: none;
            display: inline-block;
        }
        
        .cta-btn:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(67, 160, 71, 0.6);
        }
        
        /* Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
            margin-top: 60px;
        }
        
        .card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 25px;
            padding: 40px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.1);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #43a047, #66bb6a, #81c784);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }
        
        .card:hover::before {
            transform: scaleX(1);
        }
        
        .card:hover {
            transform: translateY(-20px) scale(1.03);
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.2);
        }
        
        .card-icon {
            font-size: 80px;
            color: #43a047;
            margin-bottom: 30px;
            display: block;
            text-align: center;
        }
        
        .card h3 {
            font-size: 28px;
            color: #2e7d32;
            margin-bottom: 20px;
            font-weight: 700;
            text-align: center;
        }
        
        .card p {
            color: #666;
            font-size: 18px;
            line-height: 1.8;
            text-align: center;
        }
        
        /* Messenger Button - ONLY in Shop */
        .messenger {
            position: absolute;
            top: 25px;
            right: 25px;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0084ff, #1976d2);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: white;
            box-shadow: 0 10px 30px rgba(0, 132, 255, 0.4);
            z-index: 10;
            transition: all 0.3s ease;
        }
        
        .messenger:hover {
            transform: scale(1.2) rotate(360deg);
            box-shadow: 0 20px 50px rgba(0, 132, 255, 0.6);
        }
        
        /* Shop Demo Product */
        .shop-product {
            position: relative;
        }
        
        .price-tag {
            background: linear-gradient(45deg, #4caf50, #81c784);
            color: white;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 24px;
            font-weight: bold;
            margin-top: 25px;
            display: inline-block;
            box-shadow: 0 8px 25px rgba(76, 175, 80, 0.3);
        }
        
        /* Controls */
        .controls {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 30px;
            border-radius: 25px;
            margin-bottom: 50px;
            display: flex;
            gap: 25px;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.1);
        }
        
        .search-input {
            flex: 1;
            min-width: 300px;
            padding: 20px 30px;
            border: 3px solid rgba(67, 160, 71, 0.2);
            border-radius: 50px;
            font-size: 18px;
            background: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }
        
        .search-input:focus {
            outline: none;
            border-color: #43a047;
            box-shadow: 0 0 0 5px rgba(67, 160, 71, 0.15);
            background: white;
        }
        
        /* Admin Panel */
        .admin-section {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            padding: 50px;
            border-radius: 30px;
            margin-bottom: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
        }
        
        .admin-title {
            font-size: 32px;
            color: #2e7d32;
            margin-bottom: 40px;
            text-align: center;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .header {
                padding: 12px 20px;
                flex-direction: column;
                gap: 15px;
            }
            
            .nav {
                padding: 15px 10px;
            }
            
            .nav-btn {
                padding: 12px 25px;
                font-size: 14px;
            }
            
            .hero {
                padding: 60px 30px;
                margin-bottom: 40px;
            }
            
            .hero h1 {
                font-size: 36px;
            }
            
            .grid {
                grid-template-columns: 1fr;
                gap: 30px;
            }
            
            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .cta-btn {
                width: 100%;
                max-width: 350px;
            }
            
            .controls {
                flex-direction: column;
                align-items: stretch;
            }
            
            .search-input {
                min-width: auto;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <header class="header">
        <a href="#" class="logo" onclick="showPage('home')">📚 eQro PDF Hub</a>
        <div class="header-icons">
            <button class="icon-btn" onclick="showPage('home')" title="হোম">
                <i>🏠</i>
            </button>
            <button class="icon-btn" onclick="showSettings()" title="সেটিংস">
                ⚙️
            </button>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="nav">
        <button class="nav-btn active" onclick="showPage('home')">🏠 হোম</button>
        <button class="nav-btn" onclick="showPage('pdf')">📄 PDF</button>
        <button class="nav-btn" onclick="showPage('shop')">🛒 দোকান</button>
        <button class="nav-btn" onclick="adminLogin()">🔐 অ্যাডমিন</button>
    </nav>

    <!-- Main Content -->
    <div class="page-container">
        
        <!-- Home Page -->
        <div id="home" class="page active">
            <section class="hero">
                <h1>🚀 স্বাগতম eQro PDF Hub এ!</h1>
                <p>বাংলাদেশের সেরা শিক্ষামূলক PDF হাব। চাকরির প্রস্তুতি, ভর্তি পরীক্ষা, একাডেমিক সব PDF এক জায়গায়।</p>
                <div class="cta-buttons
